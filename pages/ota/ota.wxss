page {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.scrollarea {
  flex: 1;
  width: 100%;
}

.container {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  padding-top: 20rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.ota-section {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
  backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.firmware-card {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 25rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.firmware-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.firmware-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.firmware-source {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.8);
}

.firmware-source.active {
  background: rgba(76, 175, 80, 0.5);
  color: #fff;
}

.firmware-details {
  padding-top: 15rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.detail-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.detail-value {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
  word-break: break-all;
  max-width: 60%;
  text-align: right;
}

.firmware-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 15rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.btn {
  flex: 1;
  height: 100rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s ease;
}

.btn-icon {
  margin-right: 10rpx;
  font-size: 36rpx;
}

.btn-primary {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.btn-success {
  background: rgba(76, 175, 80, 0.5);
  color: #fff;
  border: 2rpx solid rgba(76, 175, 80, 0.6);
}

.btn-warning {
  background: rgba(255, 152, 0, 0.5);
  color: #fff;
  border: 2rpx solid rgba(255, 152, 0, 0.6);
}

.btn-default {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.8);
}

.btn-outline {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.btn-small {
  height: 60rpx;
  font-size: 26rpx;
  padding: 0 30rpx;
  border-radius: 30rpx;
}

.btn-large {
  height: 110rpx;
  font-size: 36rpx;
}

.btn-icon-btn {
  height: 90rpx;
}

.btn[disabled] {
  opacity: 0.6;
}

.firmware-btns {
  margin-bottom: 30rpx;
}

.progress-section {
  background: rgba(76, 175, 80, 0.3);
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 25rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.4);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-label {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.progress-percent {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
}

.progress-bar {
  width: 100%;
  height: 24rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.progress-fill {
  height: 100%;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  transition: width 0.3s ease;
}

.progress-glow {
  position: absolute;
  top: 0;
  width: 30rpx;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent);
  transform: translateX(-50%);
  animation: glow 1.5s infinite;
}

@keyframes glow {
  0% { opacity: 0; }
  50% { opacity: 1; }
  100% { opacity: 0; }
}

.progress-status {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

.status-icon-animate {
  font-size: 32rpx;
  margin-right: 10rpx;
  animation: flash 1s infinite;
}

@keyframes flash {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.status-text {
  font-size: 26rpx;
  color: #fff;
}

.status-info {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 25rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  margin-bottom: 25rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  margin-right: 15rpx;
}

.status-dot.ready {
  background: #4CAF50;
}

.status-info text:last-child {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.action-btns {
  margin-top: 10rpx;
}

.settings-entry {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.btn-settings-link {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 20rpx;
  font-size: 28rpx;
}

.firmware-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 90%;
  max-width: 90%;
  max-height: 70vh;
  background: #fff;
  border-radius: 30rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx;
  border-bottom: 1rpx solid #eee;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 50rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 25rpx;
  box-sizing: border-box;
  width: 100%;
}

.url-input {
  width: 100%;
  height: 90rpx;
  padding: 0 25rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.modal-btn-group {
  display: flex;
  justify-content: flex-end;
  gap: 25rpx;
  margin-top: 40rpx;
}
