<navigation-bar title="Easy OTA" back="{{false}}" color="white" background="transparent"></navigation-bar>
<view class="page-bg" style="background: {{themeGradient}};"></view>
<scroll-view class="scrollarea" scroll-y scroll-anchoring="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
  <view class="container">
    <view class="header-section">
      <view class="status-icon-wrapper disconnected">
        <view class="status-icon">
          <view class="bluetooth-icon">
            <view class="bt-body"></view>
            <view class="bt-top"></view>
            <view class="bt-bottom"></view>
          </view>
        </view>
      </view>
      <text class="status-title">欢迎使用</text>
      <text class="status-subtitle">Easy OTA 蓝牙工具</text>
    </view>

    <view class="action-section">
      <view class="btn-group">
        <button class="btn btn-primary" bindtap="onConnectBluetooth">
          <text class="btn-icon">🔍</text>
          <text>搜索蓝牙设备</text>
        </button>
      </view>
      <view class="btn-group btn-group-row">
        <button class="btn btn-outline btn-tip" bindtap="onShowTip">
          <text class="btn-icon">💡</text>
          <text>使用提示</text>
        </button>
      </view>
    </view>
  </view>
</scroll-view>

<view class="device-modal" wx:if="{{showDeviceList}}">
  <view class="modal-mask" bindtap="onCloseDeviceList"></view>
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">选择蓝牙设备</text>
      <text class="modal-close" bindtap="onCloseDeviceList">×</text>
    </view>
    <scroll-view class="modal-body" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="scanning-tip" wx:if="{{isScanning}}">
        <text>正在搜索...</text>
        <button class="btn-small" bindtap="onStopScan">停止搜索</button>
      </view>
      <view class="device-list" wx:if="{{deviceList.length > 0}}">
        <view 
          class="device-item" 
          wx:for="{{deviceList}}" 
          wx:key="deviceId"
          data-device="{{item}}"
          bindtap="onSelectDevice">
          <text class="device-name">{{item.name}}</text>
          <text class="device-rssi">信号: {{item.RSSI}} dBm</text>
        </view>
      </view>
      <view class="empty-tip" wx:else>
        <text>暂未发现设备</text>
      </view>
    </scroll-view>
  </view>
</view>

<view class="tip-modal" wx:if="{{showTipModal}}">
  <view class="modal-mask" bindtap="onCloseTipModal"></view>
  <view class="modal-content tip-modal-content">
    <view class="modal-header">
      <text class="modal-title">💡 使用提示</text>
      <text class="modal-close" bindtap="onCloseTipModal">×</text>
    </view>
    <view class="modal-body tip-body">
      <view class="tip-item">
        <view class="tip-num">1</view>
        <text class="tip-desc">点击"搜索蓝牙设备"按钮，扫描附近的蓝牙设备</text>
      </view>
      <view class="tip-item">
        <view class="tip-num">2</view>
        <text class="tip-desc">从设备列表中选择要连接的目标设备</text>
      </view>
      <view class="tip-item">
        <view class="tip-num">3</view>
        <text class="tip-desc">连接成功后，进入功能选择页面</text>
      </view>
      <view class="tip-item">
        <view class="tip-num">4</view>
        <text class="tip-desc">选择需要的功能进行操作，如OTA升级、WIFI配置等</text>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-primary btn-block" bindtap="onCloseTipModal">我知道了</button>
    </view>
  </view>
</view>
