page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  width: 100%;
}

.container {
  padding: 30rpx;
  padding-bottom: 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-card {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 30rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.status-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.status-icon.connected {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
}

.status-icon.disconnected {
  background: linear-gradient(135deg, #9E9E9E, #BDBDBD);
}

.icon-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.status-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.device-name {
  font-size: 26rpx;
  color: #666;
  margin-top: 10rpx;
}

.btn-group {
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
  flex-shrink: 0;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #2196F3, #1976D2);
  color: #fff;
}

.btn-success {
  background: linear-gradient(135deg, #4CAF50, #388E3C);
  color: #fff;
}

.btn-danger {
  background: linear-gradient(135deg, #f44336, #d32f2f);
  color: #fff;
}

.btn-warning {
  background: linear-gradient(135deg, #ff9800, #f57c00);
  color: #fff;
}

.btn-default {
  background: #e0e0e0;
  color: #666;
}

.btn-outline {
  background: #fff;
  color: #2196F3;
  border: 2rpx solid #2196F3;
}

.btn-settings {
  flex: 0 0 auto;
  width: 160rpx;
  margin-left: 20rpx;
}

.btn-small {
  height: 60rpx;
  font-size: 26rpx;
  padding: 0 30rpx;
  border-radius: 30rpx;
}

.btn[disabled] {
  opacity: 0.6;
}

.ota-section {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
  flex-shrink: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.firmware-info {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.firmware-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.firmware-row:not(:last-child) {
  border-bottom: 1rpx solid #eee;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  word-break: break-all;
  max-width: 60%;
  text-align: right;
}

.firmware-btns {
  margin-bottom: 20rpx;
}

.progress-section {
  margin: 30rpx 0;
}

.progress-bar {
  width: 100%;
  height: 20rpx;
  background: #e0e0e0;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-top: 15rpx;
}

.status-info {
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
}

.device-modal,
.firmware-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 90%;
  max-width: 90%;
  max-height: 70vh;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 20rpx;
  height: 600rpx;
  box-sizing: border-box;
  width: 100%;
}

.scanning-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #e3f2fd;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  width: 100%;
}

.device-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  width: 100%;
}

.device-item {
  display: flex;
  flex-direction: column;
  padding: 25rpx 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  box-sizing: border-box;
  width: 100%;
}

.device-item:active {
  background: #e8e8e8;
}

.device-item .device-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.device-rssi {
  font-size: 24rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.url-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-btn-group {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 30rpx;
}
