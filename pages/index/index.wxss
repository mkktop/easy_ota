page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
}

.scrollarea {
  flex: 1;
  width: 100%;
}

.container {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  padding-bottom: 50rpx;
}

.header-section {
  padding: 80rpx 30rpx 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-icon-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 35rpx;
}

.status-icon-wrapper.connected .status-icon {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  box-shadow: 0 15rpx 50rpx rgba(76, 175, 80, 0.5);
}

.status-icon-wrapper.disconnected .status-icon {
  background: rgba(255, 255, 255, 0.15);
  box-shadow: 0 15rpx 50rpx rgba(0, 0, 0, 0.15);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
}

.status-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.bluetooth-icon {
  position: relative;
  width: 60rpx;
  height: 80rpx;
}

.bt-body {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 40rpx;
  height: 60rpx;
  border: 6rpx solid #fff;
  border-radius: 20rpx;
}

.bt-top {
  position: absolute;
  left: 50%;
  top: 10rpx;
  transform: translateX(-50%) rotate(45deg);
  width: 30rpx;
  height: 30rpx;
  border-top: 6rpx solid #fff;
  border-right: 6rpx solid #fff;
}

.bt-bottom {
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  transform: translateX(-50%) rotate(-45deg);
  width: 30rpx;
  height: 30rpx;
  border-bottom: 6rpx solid #fff;
  border-left: 6rpx solid #fff;
}

.pulse-ring {
  position: absolute;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(76, 175, 80, 0.5);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(1.4);
    opacity: 0;
  }
}

.status-title {
  font-size: 44rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.device-name {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 25rpx;
  font-weight: 500;
}

.status-badge {
  display: flex;
  align-items: center;
  padding: 12rpx 35rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  backdrop-filter: blur(10px);
}

.badge-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-badge.connected {
  background: rgba(76, 175, 80, 0.25);
  color: #fff;
}

.status-badge.connected .badge-dot {
  background: #4CAF50;
  box-shadow: 0 0 10rpx #4CAF50;
}

.status-badge.disconnected {
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.9);
}

.status-badge.disconnected .badge-dot {
  background: rgba(255, 255, 255, 0.6);
}

.action-section {
  padding: 0 30rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.btn-group-row {
  justify-content: center;
}

.btn-tip {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  height: 80rpx;
  flex: 0 0 auto;
  width: 200rpx;
  box-shadow: none;
}

.btn {
  flex: 1;
  height: 100rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s ease;
}

.btn-icon {
  margin-right: 10rpx;
  font-size: 36rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #2196F3, #1976D2);
  color: #fff;
  box-shadow: 0 10rpx 30rpx rgba(33, 150, 243, 0.3);
}

.btn-success {
  background: linear-gradient(135deg, #4CAF50, #388E3C);
  color: #fff;
  box-shadow: 0 10rpx 30rpx rgba(76, 175, 80, 0.3);
}

.btn-danger {
  background: linear-gradient(135deg, #f44336, #d32f2f);
  color: #fff;
  box-shadow: 0 10rpx 30rpx rgba(244, 67, 54, 0.3);
}

.btn-warning {
  background: linear-gradient(135deg, #ff9800, #f57c00);
  color: #fff;
  box-shadow: 0 10rpx 30rpx rgba(255, 152, 0, 0.3);
}

.btn-default {
  background: #e0e0e0;
  color: #666;
}

.btn-outline {
  background: #fff;
  color: #2196F3;
  border: 3rpx solid #2196F3;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
}

.btn-settings {
  flex: 0 0 auto;
  width: 180rpx;
}

.btn-small {
  height: 60rpx;
  font-size: 26rpx;
  padding: 0 30rpx;
  border-radius: 30rpx;
}

.btn-large {
  height: 110rpx;
  font-size: 36rpx;
}

.btn-icon-btn {
  height: 90rpx;
}

.btn[disabled] {
  opacity: 0.6;
}

.ota-section {
  margin: 0 30rpx;
  background: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
  flex-shrink: 0;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.firmware-card {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 25rpx;
}

.firmware-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.firmware-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.firmware-source {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #e0e0e0;
  color: #999;
}

.firmware-source.active {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  color: #fff;
}

.firmware-details {
  padding-top: 15rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  word-break: break-all;
  max-width: 60%;
  text-align: right;
}

.firmware-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 15rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

.firmware-btns {
  margin-bottom: 30rpx;
}

.progress-section {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 25rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-label {
  font-size: 28rpx;
  color: #2e7d32;
  font-weight: 500;
}

.progress-percent {
  font-size: 36rpx;
  color: #2e7d32;
  font-weight: 700;
}

.progress-bar {
  width: 100%;
  height: 24rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
  border-radius: 12rpx;
  transition: width 0.3s ease;
}

.progress-glow {
  position: absolute;
  top: 0;
  width: 30rpx;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent);
  transform: translateX(-50%);
  animation: glow 1.5s infinite;
}

@keyframes glow {
  0% { opacity: 0; }
  50% { opacity: 1; }
  100% { opacity: 0; }
}

.progress-status {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

.status-icon-animate {
  font-size: 32rpx;
  margin-right: 10rpx;
  animation: flash 1s infinite;
}

@keyframes flash {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.status-text {
  font-size: 26rpx;
  color: #2e7d32;
}

.status-info {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 25rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  margin-bottom: 25rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ccc;
  margin-right: 15rpx;
}

.status-dot.ready {
  background: #4CAF50;
}

.status-info text:last-child {
  font-size: 28rpx;
  color: #666;
}

.action-btns {
  margin-top: 10rpx;
}

.tips-section {
  padding: 30rpx;
}

.tip-card {
  display: flex;
  align-items: flex-start;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
}

.tip-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.tip-content {
  flex: 1;
}

.tip-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.tip-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.device-modal,
.firmware-modal,
.tip-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 90%;
  max-width: 90%;
  max-height: 70vh;
  background: #fff;
  border-radius: 30rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx;
  border-bottom: 1rpx solid #eee;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 50rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 25rpx;
  height: 600rpx;
  box-sizing: border-box;
  width: 100%;
}

.scanning-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border-radius: 16rpx;
  margin-bottom: 25rpx;
  box-sizing: border-box;
  width: 100%;
}

.scanning-tip text {
  color: #1976D2;
  font-size: 28rpx;
}

.device-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.device-item {
  display: flex;
  flex-direction: column;
  padding: 30rpx 25rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 16rpx;
  box-sizing: border-box;
  width: 100%;
}

.device-item:active {
  background: linear-gradient(135deg, #e8e8e8 0%, #d8d8d8 100%);
}

.device-item .device-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 10rpx;
  word-break: break-all;
}

.device-rssi {
  font-size: 26rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 30rpx;
}

.url-input {
  width: 100%;
  height: 90rpx;
  padding: 0 25rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.modal-btn-group {
  display: flex;
  justify-content: flex-end;
  gap: 25rpx;
  margin-top: 40rpx;
}

.tip-modal-content {
  max-height: 80vh;
}

.tip-body {
  height: auto;
  padding: 30rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tip-desc {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding-top: 8rpx;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
}

.btn-block {
  width: 100%;
}
