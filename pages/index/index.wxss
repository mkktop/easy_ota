page {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.scrollarea {
  flex: 1;
  width: 100%;
  height: 100%;
}

.container {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  padding-bottom: 50rpx;
}

.header-section {
  padding: 100rpx 30rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-icon-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 35rpx;
}

.status-icon-wrapper.disconnected .status-icon {
  background: rgba(255, 255, 255, 0.15);
  box-shadow: 0 15rpx 50rpx rgba(0, 0, 0, 0.15);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
}

.status-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.bluetooth-icon {
  position: relative;
  width: 60rpx;
  height: 80rpx;
}

.bt-body {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 40rpx;
  height: 60rpx;
  border: 6rpx solid #fff;
  border-radius: 20rpx;
}

.bt-top {
  position: absolute;
  left: 50%;
  top: 10rpx;
  transform: translateX(-50%) rotate(45deg);
  width: 30rpx;
  height: 30rpx;
  border-top: 6rpx solid #fff;
  border-right: 6rpx solid #fff;
}

.bt-bottom {
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  transform: translateX(-50%) rotate(-45deg);
  width: 30rpx;
  height: 30rpx;
  border-bottom: 6rpx solid #fff;
  border-left: 6rpx solid #fff;
}

.status-title {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 15rpx;
  letter-spacing: 2rpx;
}

.status-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.action-section {
  padding: 0 30rpx;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.btn-group-row {
  justify-content: center;
}

.btn {
  flex: 1;
  height: 100rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s ease;
  white-space: nowrap;
}

.btn-icon {
  margin-right: 10rpx;
  font-size: 36rpx;
}

.btn-primary {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: none;
}

.btn-outline {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: none;
}

.btn-tip {
  height: 80rpx;
  flex: 0 0 auto;
  width: 200rpx;
}

.btn-small {
  height: 60rpx;
  font-size: 26rpx;
  padding: 0 30rpx;
  border-radius: 30rpx;
}

.btn-block {
  width: 100%;
}

.device-modal,
.tip-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 90%;
  max-width: 90%;
  max-height: 70vh;
  background: #fff;
  border-radius: 30rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx;
  border-bottom: 1rpx solid #eee;
  box-sizing: border-box;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 50rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 25rpx;
  height: 600rpx;
  box-sizing: border-box;
  width: 100%;
}

.scanning-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border-radius: 16rpx;
  margin-bottom: 25rpx;
  box-sizing: border-box;
  width: 100%;
}

.scanning-tip text {
  color: #1976D2;
  font-size: 28rpx;
}

.device-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.device-item {
  display: flex;
  flex-direction: column;
  padding: 30rpx 25rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 16rpx;
  box-sizing: border-box;
  width: 100%;
}

.device-item:active {
  background: linear-gradient(135deg, #e8e8e8 0%, #d8d8d8 100%);
}

.device-item .device-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 10rpx;
  word-break: break-all;
}

.device-rssi {
  font-size: 26rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 30rpx;
}

.tip-modal-content {
  max-height: 80vh;
}

.tip-body {
  height: auto;
  padding: 30rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tip-desc {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding-top: 8rpx;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
}
