page {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.scrollarea {
  flex: 1;
  width: 100%;
}

.container {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  padding-bottom: 50rpx;
}

.header-section {
  padding: 80rpx 30rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-icon-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 35rpx;
}

.status-icon-wrapper.connected .status-icon {
  background: rgba(76, 175, 80, 0.3);
  box-shadow: 0 15rpx 50rpx rgba(76, 175, 80, 0.3);
}

.status-icon-wrapper.disconnected .status-icon {
  background: rgba(255, 255, 255, 0.15);
  box-shadow: 0 15rpx 50rpx rgba(0, 0, 0, 0.15);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
}

.status-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.bluetooth-icon {
  position: relative;
  width: 60rpx;
  height: 80rpx;
}

.bt-body {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 40rpx;
  height: 60rpx;
  border: 6rpx solid #fff;
  border-radius: 20rpx;
}

.bt-top {
  position: absolute;
  left: 50%;
  top: 10rpx;
  transform: translateX(-50%) rotate(45deg);
  width: 30rpx;
  height: 30rpx;
  border-top: 6rpx solid #fff;
  border-right: 6rpx solid #fff;
}

.bt-bottom {
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  transform: translateX(-50%) rotate(-45deg);
  width: 30rpx;
  height: 30rpx;
  border-bottom: 6rpx solid #fff;
  border-left: 6rpx solid #fff;
}

.pulse-ring {
  position: absolute;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(76, 175, 80, 0.5);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(1.4);
    opacity: 0;
  }
}

.status-title {
  font-size: 44rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.device-name {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 25rpx;
  font-weight: 500;
}

.status-badge {
  display: flex;
  align-items: center;
  padding: 12rpx 35rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  backdrop-filter: blur(10px);
}

.badge-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-badge.connected {
  background: rgba(76, 175, 80, 0.25);
  color: #fff;
}

.status-badge.connected .badge-dot {
  background: #4CAF50;
  box-shadow: 0 0 10rpx #4CAF50;
}

.status-badge.disconnected {
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.9);
}

.status-badge.disconnected .badge-dot {
  background: rgba(255, 255, 255, 0.6);
}

.menu-section {
  padding: 30rpx;
}

.menu-list {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 35rpx 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
  transition: background 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.15);
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 25rpx;
}

.menu-content {
  flex: 1;
}

.menu-title {
  display: block;
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.menu-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.menu-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
}

.action-section {
  padding: 30rpx;
  margin-top: auto;
}

.btn-disconnect {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}
