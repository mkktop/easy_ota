<navigation-bar title="全局设置" back="{{true}}" color="white" background="transparent"></navigation-bar>
<view class="page-bg" style="background: {{themeGradient}};"></view>
<scroll-view class="scrollarea" scroll-y scroll-anchoring="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
  <view class="container">
    <view class="section">
      <view class="section-header">
        <text class="section-title">🎨 主题设置</text>
      </view>
      <view class="theme-list">
        <view 
          class="theme-item {{currentThemeId === item.id ? 'active' : ''}}" 
          wx:for="{{themes}}" 
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onThemeChange">
          <view class="theme-preview" style="background: {{item.gradient}};"></view>
          <text class="theme-name">{{item.name}}</text>
          <view class="theme-check" wx:if="{{currentThemeId === item.id}}">✓</view>
        </view>
      </view>
    </view>

    <view class="section" wx:if="{{isConnected}}">
      <view class="section-header">
        <text class="section-title">📡 蓝牙特征值</text>
        <button class="btn-refresh" bindtap="onRefresh" disabled="{{loading}}">
          刷新
        </button>
      </view>
      
      <view class="current-config">
        <view class="config-row">
          <text class="config-label">服务UUID:</text>
          <text class="config-value">{{currentServiceId || '未设置'}}</text>
        </view>
        <view class="config-row">
          <text class="config-label">写入特征值:</text>
          <text class="config-value">{{currentWriteCharId || '未设置'}}</text>
        </view>
        <view class="config-row">
          <text class="config-label">通知特征值:</text>
          <text class="config-value">{{currentNotifyCharId || '未设置'}}</text>
        </view>
      </view>

      <view class="picker-group">
        <view class="picker-item">
          <text class="picker-label">写入特征值:</text>
          <picker 
            mode="selector" 
            range="{{writeCharacteristics}}" 
            range-key="uuid"
            bindchange="onWriteCharChange">
            <view class="picker-value">
              {{selectedWriteCharId || '请选择'}}
            </view>
          </picker>
        </view>

        <view class="picker-item">
          <text class="picker-label">通知特征值:</text>
          <picker 
            mode="selector" 
            range="{{notifyCharacteristics}}" 
            range-key="uuid"
            bindchange="onNotifyCharChange">
            <view class="picker-value">
              {{selectedNotifyCharId || '请选择'}}
            </view>
          </picker>
        </view>

        <view class="picker-item">
          <text class="picker-label">服务UUID:</text>
          <view class="picker-value disabled">
            {{selectedServiceId || '自动匹配'}}
          </view>
        </view>
      </view>

      <view class="tip-text">
        提示：选择写入特征值时会自动匹配对应的服务UUID
      </view>

      <button class="btn-save" bindtap="onSaveSettings" disabled="{{loading || !selectedWriteCharId}}">
        {{loading ? '保存中...' : '保存特征值设置'}}
      </button>
    </view>

    <view class="section" wx:if="{{!isConnected}}">
      <view class="empty-tip">
        <text class="empty-icon">📡</text>
        <text class="empty-text">请先连接蓝牙设备以配置特征值</text>
      </view>
    </view>
  </view>
</scroll-view>

<tab-bar current="feature" />
