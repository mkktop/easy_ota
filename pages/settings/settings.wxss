page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}

.status-card {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-row .label {
  font-size: 28rpx;
  color: #666;
}

.status-row .value {
  font-size: 28rpx;
  font-weight: 500;
}

.status-row .value.connected {
  color: #4CAF50;
}

.status-row .value.disconnected {
  color: #f44336;
}

.section {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.btn-refresh {
  font-size: 24rpx;
  padding: 10rpx 30rpx;
  background: linear-gradient(135deg, #2196F3, #1976D2);
  color: #fff;
  border-radius: 30rpx;
  border: none;
}

.btn-refresh[disabled] {
  opacity: 0.6;
}

.current-config {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}

.config-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 15rpx 0;
}

.config-row:not(:last-child) {
  border-bottom: 1rpx solid #eee;
}

.config-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.config-value {
  font-size: 24rpx;
  color: #333;
  word-break: break-all;
  text-align: right;
  margin-left: 20rpx;
}

.picker-group {
  margin-bottom: 20rpx;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.picker-label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.picker-value {
  font-size: 26rpx;
  color: #2196F3;
  text-align: right;
  word-break: break-all;
  max-width: 60%;
}

.picker-value.disabled {
  color: #999;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 30rpx;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #4CAF50, #388E3C);
  color: #fff;
  border: none;
}

.btn-save[disabled] {
  opacity: 0.6;
  background: #ccc;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
