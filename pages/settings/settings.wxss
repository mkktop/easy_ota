page {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.scrollarea {
  flex: 1;
  width: 100%;
}

.container {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.section {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
  backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.btn-refresh {
  font-size: 24rpx;
  padding: 10rpx 30rpx;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.btn-refresh[disabled] {
  opacity: 0.6;
}

.theme-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.theme-item {
  width: calc(33.33% - 14rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  position: relative;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.theme-item.active {
  background: rgba(255, 255, 255, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.6);
}

.theme-preview {
  width: 100%;
  height: 80rpx;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.theme-name {
  font-size: 24rpx;
  color: #fff;
}

.theme-check {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(255, 255, 255, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.current-config {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.config-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 15rpx 0;
}

.config-row:not(:last-child) {
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.config-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  flex-shrink: 0;
}

.config-value {
  font-size: 24rpx;
  color: #fff;
  word-break: break-all;
  text-align: right;
  margin-left: 20rpx;
}

.picker-group {
  margin-bottom: 20rpx;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 20rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.picker-label {
  font-size: 28rpx;
  color: #fff;
  flex-shrink: 0;
}

.picker-value {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: right;
  word-break: break-all;
  max-width: 60%;
}

.picker-value.disabled {
  color: rgba(255, 255, 255, 0.6);
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
  margin-bottom: 30rpx;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.btn-save[disabled] {
  opacity: 0.6;
  background: rgba(255, 255, 255, 0.15);
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}
