page {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.scrollarea {
  flex: 1;
  width: 100%;
}

.container {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.status-section {
  padding: 100rpx 30rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-icon-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 35rpx;
}

.status-icon-wrapper.disconnected .status-icon {
  background: rgba(255, 255, 255, 0.15);
  box-shadow: 0 15rpx 50rpx rgba(0, 0, 0, 0.15);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
}

.status-icon-wrapper.connected .status-icon {
  background: rgba(76, 175, 80, 0.3);
  box-shadow: 0 15rpx 50rpx rgba(76, 175, 80, 0.3);
  border: 3rpx solid rgba(76, 175, 80, 0.5);
}

.status-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.pulse-ring {
  position: absolute;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(76, 175, 80, 0.5);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.5); opacity: 0; }
}

.paper-plane {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  transform: rotate(-45deg);
}

.plane-body {
  position: absolute;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 15rpx solid transparent;
  border-right: 15rpx solid transparent;
  border-bottom: 50rpx solid #fff;
}

.plane-wing-left {
  position: absolute;
  left: -5rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 25rpx solid transparent;
  border-top: 15rpx solid rgba(255, 255, 255, 0.7);
  transform: rotate(-10deg);
}

.plane-wing-right {
  position: absolute;
  right: -5rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border-right: 20rpx solid transparent;
  border-left: 25rpx solid transparent;
  border-top: 15rpx solid rgba(255, 255, 255, 0.7);
  transform: rotate(10deg);
}

.plane-trail {
  position: absolute;
  left: 50%;
  bottom: -25rpx;
  transform: translateX(-50%);
  width: 6rpx;
  height: 20rpx;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0.8), transparent);
  border-radius: 3rpx;
  animation: trail-pulse 1.5s infinite;
}

@keyframes trail-pulse {
  0%, 100% { opacity: 0.3; height: 20rpx; }
  50% { opacity: 1; height: 30rpx; }
}

.status-title {
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 15rpx;
}

.device-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.status-badge {
  display: flex;
  align-items: center;
  padding: 12rpx 35rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  backdrop-filter: blur(10px);
}

.badge-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-badge.connected {
  background: rgba(76, 175, 80, 0.25);
  color: #fff;
}

.status-badge.connected .badge-dot {
  background: #4CAF50;
  box-shadow: 0 0 10rpx #4CAF50;
}

.status-badge.disconnected {
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.9);
}

.status-badge.disconnected .badge-dot {
  background: rgba(255, 255, 255, 0.6);
}

.power-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.2s ease;
}

.power-btn:active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(0.95);
}

.power-icon {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  position: relative;
}

.power-icon::before {
  content: '';
  position: absolute;
  left: 50%;
  top: -8rpx;
  transform: translateX(-50%);
  width: 4rpx;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 2rpx;
}

.action-section {
  padding: 0 30rpx;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.btn {
  flex: 1;
  height: 100rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s ease;
  white-space: nowrap;
}

.btn-icon {
  margin-right: 10rpx;
  font-size: 36rpx;
}

.btn-primary {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.btn-danger {
  background: rgba(255, 82, 82, 0.4);
  color: #fff;
  border: 2rpx solid rgba(255, 82, 82, 0.6);
}

.info-section {
  padding: 30rpx;
}

.info-card {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  text-align: center;
}

.connected-name {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.device-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 90%;
  max-height: 80%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 30rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 50rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  padding: 25rpx;
  min-height: 500rpx;
  max-height: 700rpx;
}

.scanning-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 25rpx;
  font-size: 28rpx;
  color: #666;
}

.btn-small {
  height: 64rpx;
  font-size: 26rpx;
  padding: 0 35rpx;
  border-radius: 32rpx;
  background: #667eea;
  color: #fff;
  border: none;
}

.device-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.device-item {
  padding: 35rpx 30rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.device-item:active {
  background: #f0f0f0;
}

.device-item .device-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.device-rssi {
  font-size: 26rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
