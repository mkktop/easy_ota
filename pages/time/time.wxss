page {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 140rpx;
}

.coming-soon {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.coming-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.coming-title {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.coming-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}
