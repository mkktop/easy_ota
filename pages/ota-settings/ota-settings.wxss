page {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.scrollarea {
  flex: 1;
  width: 100%;
}

.container {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  padding-bottom: 50rpx;
  box-sizing: border-box;
}

.section {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
  backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.section-header {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.ota-settings {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 20rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.setting-label {
  display: flex;
  align-items: baseline;
}

.label-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.label-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-left: 8rpx;
}

.setting-input-wrap {
  width: 200rpx;
}

.setting-input {
  width: 100%;
  height: 70rpx;
  padding: 0 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  box-sizing: border-box;
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.setting-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.setting-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.switch-item {
  margin-top: 10rpx;
}

.setting-btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-reset {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.btn-save {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}
